<section class="relative h-screen w-full overflow-hidden bg-luxury-black" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <!-- Background Image with continuous slow scale/pan and scroll parallax -->
  <div class="absolute inset-0 z-0 origin-center scale-105 transition-transform duration-1000">
    {% if section.settings.image != blank %}
      <img
        src="{{ section.settings.image | image_url: width: 2000 }}"
        alt="{{ section.settings.title | escape }}"
        class="w-full h-full object-cover object-center opacity-70"
      >
    {% else %}
      <img
        src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&q=80&w=2000"
        alt="Default Luxury Hero"
        class="w-full h-full object-cover object-center opacity-70"
      >
    {% endif %}
    <!-- Luxury dark background gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-luxury-black via-luxury-black/30 to-luxury-black/60"></div>
  </div>

  <!-- Geometric grid pattern lines overlay -->
  <div class="absolute inset-0 z-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNDAiIGhlaWdodD0iNDAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+CjxhcmNoIGZpbGw9Im5vbmUiIHN0cm9rZT0icmdiYSgyNTUsMjU1LDI1NSwwLjA1KSIgc3Ryb2tlLXdpZHRoPSIxIiBkPSJNMCAwdjQwaDQwVjBIMHoiLz4KPC9zdmc+')] opacity-20 hidden md:block"></div>

  <!-- Content -->
  <div class="relative z-10 h-full flex flex-col justify-end max-w-7xl mx-auto px-6 md:px-12 pb-32">
    <div class="max-w-3xl animate-on-scroll transition-all duration-1000 transform translate-y-10 opacity-0">
      <div class="flex items-center gap-4 mb-6">
        <span class="h-[1px] w-12 bg-luxury-gold" style="background-color: var(--color-accent);"></span>
        <p class="text-luxury-gold uppercase tracking-[0.3em] text-xs font-bold" style="color: var(--color-accent);">
          {{ section.settings.tagline | default: 'The Protocol 01' }}
        </p>
      </div>
      
      <h1 class="text-5xl md:text-7xl lg:text-8xl text-white leading-[1.1] mb-6 font-headings font-serif" style="font-family: var(--font-heading);">
        {{ section.settings.title }}
      </h1>
      
      <p class="text-gray-300 text-lg md:text-xl font-light mb-12 max-w-xl leading-relaxed">
        {{ section.settings.subtitle }}
      </p>
      
      <div class="flex flex-col sm:flex-row gap-6">
        {% if section.settings.button_1_label != blank %}
          <a href="{{ section.settings.button_1_link }}" class="bg-white text-black text-center px-10 py-5 uppercase tracking-[0.2em] text-xs font-bold hover:bg-luxury-gold hover:text-black transition-colors w-full sm:w-auto interactive-element">
            {{ section.settings.button_1_label }}
          </a>
        {% endif %}
        {% if section.settings.button_2_label != blank %}
          <a href="{{ section.settings.button_2_link }}" class="border border-white/50 text-white text-center px-10 py-5 uppercase tracking-[0.2em] text-xs font-bold hover:border-white hover:bg-white/10 backdrop-blur-sm transition-all w-full sm:w-auto interactive-element">
            {{ section.settings.button_2_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Luxury Banner Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Cover image"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Top Tagline text",
      "default": "The Protocol 01"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Main Header Title",
      "default": "Scientific Elegance"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle Description Paragraph",
      "default": "Advanced longevity solutions crafted with unapologetic purity and clinical precision. Engineer your biological future."
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Button 1 Label CTA",
      "default": "Discover Protocol"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 Link destination"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Button 2 Label CTA",
      "default": "View Formulations"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 Link destination"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Section Top padding spacing modifier",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Section Bottom padding spacing modifier",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Luxury Banner Hero"
    }
  ]
}
{% endschema %}
