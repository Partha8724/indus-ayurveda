<section class="py-24 bg-luxury-black text-white min-h-[60vh] flex items-center" id="shopify-section-main-search" style="background-color: var(--color-bg);">
  <div class="max-w-7xl mx-auto px-6 md:px-12 w-full animate-on-scroll">
    <div class="mb-12 border-b border-white/10 pb-8 text-center">
      <h1 class="text-4xl md:text-5xl font-serif mb-6" style="font-family: var(--font-heading);">
        {% if search.performed %}
          Search Results: &ldquo;{{ search.terms }}&rdquo;
        {% else %}
          Search the Store
        {% endif %}
      </h1>
      
      <!-- Native Search form field -->
      <form action="/search" method="get" role="search" class="max-w-md mx-auto relative flex">
        <input 
          type="search" 
          name="q" 
          value="{{ search.terms | escape }}" 
          placeholder="Search formulations, ingredients, logs..." 
          class="w-full bg-white/5 border border-white/10 px-6 py-4 text-sm text-white focus:outline-none focus:border-luxury-gold tracking-wider placeholder-gray-500 rounded-none"
        >
        <button type="submit" class="bg-[#d4af37] hover:bg-white text-black px-8 py-4 uppercase tracking-widest text-xs font-bold rounded-none interactive-element" style="background-color: var(--color-accent);">
          Find
        </button>
      </form>
    </div>

    {% if search.performed %}
      {% if search.results_count > 0 %}
        <!-- Search Results Grid -->
        <div class="text-sm font-mono text-luxury-gold tracking-widest uppercase mb-12" style="color: var(--color-accent);">
          {{ search.results_count }} Results Found
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
          {% for item in search.results %}
            {% if item.object_type == 'product' %}
              <a href="{{ item.url }}" class="group block interactive-card border border-white/5 bg-white/5 hover:border-luxury-gold hover:bg-white/10 transition-all p-6 relative">
                <div class="aspect-square w-full overflow-hidden bg-white/5 mb-6">
                  {% if item.featured_media != blank %}
                    <img 
                      src="{{ item.featured_media | image_url: width: 600 }}" 
                      alt="{{ item.title | escape }}" 
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                    >
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'w-full h-full text-white/10' }}
                  {% endif %}
                </div>

                <div class="text-xs uppercase tracking-widest text-[#d4af37] mb-2 font-bold" style="color: var(--color-accent);">
                  {{ item.vendor }}
                </div>
                <h3 class="text-lg font-serif mb-2 text-white group-hover:text-luxury-gold transition-colors font-sans" style="font-family: var(--font-heading);">
                  {{ item.title }}
                </h3>
                <div class="text-sm font-mono text-gray-400">
                  {{ item.price | money }}
                </div>
              </a>
            {% else %}
              <!-- General Article/Page search result card -->
              <a href="{{ item.url }}" class="group block border border-white/10 bg-white/5 hover:border-luxury-gold hover:bg-white/10 transition-all p-8 relative">
                <span class="text-xs font-mono text-luxury-gold tracking-widest uppercase mb-4 block" style="color: var(--color-accent);">{{ item.object_type }}</span>
                <h3 class="text-xl font-serif mb-4 text-white font-sans" style="font-family: var(--font-heading);">{{ item.title }}</h3>
                <p class="text-sm text-gray-400 font-light line-clamp-3 leading-relaxed">{{ item.content | strip_html | truncate: 150 }}</p>
              </a>
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <div class="py-12 text-center">
          <p class="text-gray-400 font-light mb-6">We could not find any results matches for your query. Let's try another search.</p>
        </div>
      {% endif %}
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Main Search Results",
  "settings": []
}
{% endschema %}
