<section class="py-32 bg-luxury-black relative" id="shopify-section-featured-collection" style="background-color: var(--color-bg);">
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    
    <!-- Top Row Title Grid description -->
    <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-6 animate-on-scroll transition-all duration-1000 transform translate-y-10 opacity-0">
      <div>
        <h2 class="text-4xl md:text-6xl text-white mb-6 font-headings font-serif" style="font-family: var(--font-heading);">
          {{ section.settings.heading | default: 'Signature Formulations' }}
        </h2>
        <p class="text-gray-400 font-light max-w-lg text-lg leading-relaxed">
          {{ section.settings.subheading | default: 'Explore our clinical-grade botanical engineering, crafted with uncompromising attention to bioavailability.' }}
        </p>
      </div>
      <a 
        href="{{ collections[section.settings.collection].url | default: '#' }}" 
        class="uppercase tracking-[0.2em] text-xs font-bold border-b border-luxury-gold text-luxury-gold pb-2 hover:text-white hover:border-white transition-all flex items-center gap-4 group interactive-element"
        style="color: var(--color-accent); border-color: var(--color-accent);"
      >
        View Protocol <span class="group-hover:translate-x-2 transition-transform">→</span>
      </a>
    </div>

    <!-- Dynamic Columns layout grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-{{ section.settings.columns_desktop }} gap-x-8 gap-y-16">
      
      {%- assign collection = collections[section.settings.collection] -%}
      {%- if collection != blank and collection.all_products_count > 0 -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <div class="animate-on-scroll transition-all duration-1000 transform translate-y-10 opacity-0 group" style="transition-delay: {{ forloop.index | times: 100 }}ms;">
            
            <div class="relative aspect-[3/4] overflow-hidden bg-luxury-charcoal mb-4 interactive-card">
              <!-- Custom Interactive Status Badges -->
              {% if section.settings.show_badges %}
                <div class="absolute top-4 left-4 z-20 flex flex-col gap-2">
                  {% if product.tags contains 'New' or product.created_at_fractional_days < 30 %}
                    <span class="bg-white text-black text-[10px] uppercase tracking-widest px-2 py-1 font-bold">New</span>
                  {% endif %}
                  {% if product.tags contains 'Limited' %}
                    <span class="text-black text-[10px] uppercase tracking-widest px-2 py-1 font-bold" style="background-color: var(--color-accent);">Limited</span>
                  {% endif %}
                  {% if product.compare_at_price > product.price %}
                    <span class="bg-[#cc0000] text-white text-[10px] uppercase tracking-widest px-2 py-1 font-bold">Sale</span>
                  {% endif %}
                </div>
              {% endif %}

              <!-- Image Flip Card Hover system -->
              <div class="w-full h-full relative overflow-hidden">
                <img 
                  src="{{ product.featured_media | image_url: width: 800 }}" 
                  alt="{{ product.title | escape }}" 
                  class="absolute inset-0 w-full h-full object-cover transition-all duration-700 ease-out group-hover:scale-105 group-hover:opacity-0 z-10" 
                  loading="lazy"
                >
                {% if product.media[1] != blank %}
                  <img 
                    src="{{ product.media[1] | image_url: width: 800 }}" 
                    alt="{{ product.title | escape }} Alternate" 
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105 z-0" 
                    loading="lazy"
                  >
                {% else %}
                  <img 
                    src="{{ product.featured_media | image_url: width: 800 }}" 
                    alt="{{ product.title | escape }} Default duplicate" 
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105 z-0" 
                    loading="lazy"
                  >
                {% endif %}
              </div>

              <!-- Cart actions slide up system -->
              <div class="absolute bottom-0 left-0 w-full p-4 flex gap-2 z-20 transition-transform duration-500 transform translate-y-full group-hover:translate-y-0">
                <form action="/cart/add" method="post" class="flex-grow flex gap-2">
                  <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                  <button type="submit" class="flex-grow bg-white text-black py-3 text-xs uppercase tracking-wider font-bold hover:bg-gray-200 transition-colors flex items-center justify-center gap-2 interactive-element">
                    Add To Cart
                  </button>
                </form>
                <a href="{{ product.url }}" class="w-12 bg-luxury-black text-white py-3 flex items-center justify-center hover:text-luxury-gold transition-colors interactive-element">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                </a>
              </div>
            </div>

            <!-- Product description text details -->
            <div class="text-center md:text-left">
              <h3 class="font-serif text-lg text-white mb-2">{{ product.title }}</h3>
              <p class="text-luxury-gold text-sm tracking-widest" style="color: var(--color-accent);">{{ product.price | money_with_currency }}</p>
            </div>

          </div>
        {%- endfor -%}
      {%- else -%}
        <!-- Fallback Dummy representation when no collection is linked -->
        {%- for i in (1..4) -%}
          {%- capture dummy_title -%}
            {%- cycle 'Cellular Renewal Complex', 'Vitality Botanical Elixir', 'Immunity Defense Shield', 'Indus Detox Cleanse' -%}
          {%- endcapture -%}
          {%- capture dummy_price -%}
            {%- cycle '₹14,999', '₹9,999', '₹6,999', '₹12,499' -%
          {%- endcapture -%}
          {%- capture dummy_img -%}
            {%- cycle 'https://images.unsplash.com/photo-1620916566398-39f1143ab7be?auto=format&fit=crop&q=80&w=600', 'https://images.unsplash.com/photo-1608248593853-add12f94b8e0?auto=format&fit=crop&q=80&w=600', 'https://images.unsplash.com/photo-1584308666744-24d1e2e46b61?auto=format&fit=crop&q=80&w=600', 'https://images.unsplash.com/photo-1544161515-4ab6ce6db874?auto=format&fit=crop&q=80&w=600' -%}
          {%- endcapture -%}
          <div class="animate-on-scroll transition-all duration-1000 transform translate-y-10 opacity-0 group" style="transition-delay: {{ i | times: 100 }}ms;">
            <div class="relative aspect-[3/4] overflow-hidden bg-luxury-charcoal mb-4 interactive-card">
              <img src="{{ dummy_img }}" alt="{{ dummy_title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
            </div>
            <div class="text-center md:text-left">
              <h3 class="font-serif text-lg text-white mb-2">{{ dummy_title }}</h3>
              <p class="text-luxury-gold text-sm tracking-widest" style="color: var(--color-accent);">{{ dummy_price }}</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Collection Grid Heading",
      "default": "Signature Formulations"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Collection Description text",
      "default": "Explore our clinical-grade botanical engineering, crafted with uncompromising attention to bioavailability."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Target Shopify Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products limit display count",
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns Count on Desktop Grid",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "Toggle displaying product status badges",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured Collection Grid"
    }
  ]
}
{% endschema %}
