<section class="py-24 bg-white text-black" id="shopify-section-product-showcase">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      
      <!-- Left side: Triple Image Gallery Grid system -->
      <div class="space-y-4">
        <div class="aspect-square bg-gray-100 overflow-hidden animate-on-scroll transition-all duration-1000 transform translate-y-10 opacity-0">
          <img 
            src="{{ section.settings.image_1 | default: 'https://images.unsplash.com/photo-1594042898038-04f12f913d8a?auto=format&fit=crop&q=80&w=1000' }}" 
            alt="Product View Major" 
            class="w-full h-full object-cover"
          >
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="aspect-square bg-gray-100 overflow-hidden animate-on-scroll transition-all duration-1000 transform translate-y-10 opacity-0" style="transition-delay: 200ms;">
            <img 
              src="{{ section.settings.image_2 | default: 'https://images.unsplash.com/photo-1577401239170-897942555fb3?auto=format&fit=crop&q=80&w=800' }}" 
              alt="Product Detail View 2" 
              class="w-full h-full object-cover"
            >
          </div>
          <div class="aspect-square bg-gray-100 overflow-hidden animate-on-scroll transition-all duration-1000 transform translate-y-10 opacity-0" style="transition-delay: 400ms;">
            <img 
              src="{{ section.settings.image_3 | default: 'https://images.unsplash.com/photo-1629851602715-ddca935e4eeb?auto=format&fit=crop&q=80&w=800' }}" 
              alt="Extraction Laboratory View 3" 
              class="w-full h-full object-cover"
            >
          </div>
        </div>
      </div>

      <!-- Right side: Product Interactive Checkout controls -->
      <div class="lg:py-12 flex flex-col justify-center animate-on-scroll transition-all duration-1000 transform translate-y-10 opacity-0" style="transition-delay: 200ms;">
        <p class="text-luxury-gold uppercase tracking-[0.2em] text-xs font-bold mb-4" style="color: var(--color-accent);">
          {{ section.settings.badge | default: 'Wellness / Immune Support' }}
        </p>
        <h1 class="text-4xl md:text-5xl font-serif mb-4" style="font-family: var(--font-heading);">
          {{ section.settings.title | default: 'The Vitality Core Caps' }}
        </h1>
        <p class="text-xl font-light mb-8">
          ₹{{ section.settings.price | default: 9999 }} <span class="text-sm text-gray-400 ml-2">/ 60 Capsules</span>
        </p>
        
        <p class="text-gray-600 mb-8 leading-relaxed font-light">
          {{ section.settings.description | default: 'Elevate your daily routine. The Vitality Core Caps transcend traditional supplementation, blending ancient herbal intelligence with cutting-edge bioavailability. Your foundation for everyday resilience.' }}
        </p>

        <!-- Size Selection metrics -->
        <div class="mb-8">
          <p class="text-xs uppercase tracking-widest font-bold text-gray-400 mb-3">Therapeutic Volume Presets</p>
          <div class="flex gap-3">
            <button class="px-5 py-3 border border-black text-xs uppercase tracking-widest font-bold bg-black text-white interactive-element">60 Capsules</button>
            <button class="px-5 py-3 border border-gray-200 text-xs uppercase tracking-widest font-bold text-gray-500 hover:border-black hover:text-black transition-colors interactive-element">120 Capsules (Save 10%)</button>
          </div>
        </div>

        <!-- Checkout Actions Add form -->
        <div class="flex items-center gap-4 mb-12">
          <div class="flex items-center border border-gray-200">
            <button class="px-4 py-3 hover:bg-gray-100 transition-colors text-gray-500 interactive-element" onclick="decrementVal()">-</button>
            <span id="showcase-input-val" class="px-4 font-mono text-sm font-medium">1</span>
            <button class="px-4 py-3 hover:bg-gray-100 transition-colors text-gray-500 interactive-element" onclick="incrementVal()">+</button>
          </div>
          
          <button class="flex-grow bg-black hover:bg-luxury-gold hover:text-black text-white py-4 uppercase tracking-[0.2em] text-xs font-bold transition-all interactive-element" onclick="simAddToCart()">
            Add To Cart
          </button>
        </div>

        <!-- Technical Description Tabs accordions -->
        <div class="border-t border-gray-100 pt-6">
          <!-- Accordion Tab 1: Composition -->
          <div class="border-b border-gray-100 py-4">
            <button class="w-full flex justify-between items-center text-left py-2 font-medium text-sm text-gray-800 focus:outline-none interactive-element" onclick="toggleAnalysisTab('comp')">
              <span class="uppercase tracking-widest text-xs font-bold">Scientific Composition</span>
              <span id="comp-arrow" class="font-serif text-lg leading-none transition-transform">&#43;</span>
            </button>
            <div id="tab-comp-body" class="max-h-0 overflow-hidden transition-all duration-300">
              <p class="py-4 text-sm text-gray-600 leading-relaxed font-light">
                Features hyper-purified Organic Ashwagandha with an industry-leading 10% Withanolides profile, layered with Shilajit minerals and piperine-enhanced bioavailability matrices.
              </p>
            </div>
          </div>
          
          <!-- Accordion Tab 2: Trials -->
          <div class="border-b border-gray-100 py-4">
            <button class="w-full flex justify-between items-center text-left py-2 font-medium text-sm text-gray-800 focus:outline-none interactive-element" onclick="toggleAnalysisTab('trials')">
              <span class="uppercase tracking-widest text-xs font-bold">Clinical Trials & Efficacy</span>
              <span id="trials-arrow" class="font-serif text-lg leading-none transition-transform">&#43;</span>
            </button>
            <div id="tab-trials-body" class="max-h-0 overflow-hidden transition-all duration-300">
              <p class="py-4 text-sm text-gray-600 leading-relaxed font-light">
                Double-blind placebo controlled model studies demonstrated a 34% drop in cortisol baseline and an enhanced cellular oxygen uptake within 14 days of sustained usage.
              </p>
            </div>
          </div>

          <!-- Accordion Tab 3: Method -->
          <div class="border-b border-gray-100 py-4">
            <button class="w-full flex justify-between items-center text-left py-2 font-medium text-sm text-gray-800 focus:outline-none interactive-element" onclick="toggleAnalysisTab('method')">
              <span class="uppercase tracking-widest text-xs font-bold">Method & Ritual</span>
              <span id="method-arrow" class="font-serif text-lg leading-none transition-transform">&#43;</span>
            </button>
            <div id="tab-method-body" class="max-h-0 overflow-hidden transition-all duration-300">
              <p class="py-4 text-sm text-gray-600 leading-relaxed font-light">
                Consume 2 capsules each morning before raw light breaks. Pair with clean, warm structured water to optimize bioavailability pathways first thing in the morning.
              </p>
            </div>
          </div>
        </div>

      </div>

    </div>
  </div>
</section>

<script>
  let showcaseQty = 1;
  const decrementVal = () => {
    if (showcaseQty > 1) {
      showcaseQty--;
      document.getElementById('showcase-input-val').innerText = showcaseQty;
    }
  };
  const incrementVal = () => {
    showcaseQty++;
    document.getElementById('showcase-input-val').innerText = showcaseQty;
  };

  const simAddToCart = () => {
    // Open dynamic navigation drawer on cart additions
    toggleCartDrawer();
  };

  const toggleAnalysisTab = (id) => {
    const body = document.getElementById(`tab-${id}-body`);
    const arrow = document.getElementById(`${id}-arrow`);
    if (body.style.maxHeight === '150px') {
      body.style.maxHeight = '0px';
      arrow.innerHTML = '&#43;';
    } else {
      // Collapse others
      document.querySelectorAll('[id$="-body"]').forEach(el => el.style.maxHeight = '0px');
      document.querySelectorAll('[id$="-arrow"]').forEach(el => el.innerHTML = '&#43;');
      body.style.maxHeight = '150px';
      arrow.innerHTML = '&#8722;';
    }
  };
</script>

{% schema %}
{
  "name": "Interactive Showcase Item",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Major Hero Image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Secondary Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Laboratory Image 3"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge Category label",
      "default": "Wellness / Immune Support"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Item Showcase Name",
      "default": "The Vitality Core Caps"
    },
    {
      "type": "number",
      "id": "price",
      "label": "Item Price (Numeric)",
      "default": 9999
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Item full introduction narrative",
      "default": "Elevate your daily routine. The Vitality Core Caps transcend traditional supplementation, blending ancient herbal intelligence with cutting-edge bioavailability. Your foundation for everyday resilience."
    }
  ],
  "presets": [
    {
      "name": "Interactive Showcase Item"
    }
  ]
}
{% endschema %}
