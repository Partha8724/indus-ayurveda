<section class="py-24 bg-luxury-black text-white" id="shopify-section-main-page" style="background-color: var(--color-bg);">
  <div class="max-w-4xl mx-auto px-6 md:px-12 animate-on-scroll">
    <div class="mb-12 border-b border-white/10 pb-8 text-center">
      <h1 class="text-4xl md:text-5xl font-serif mb-4" style="font-family: var(--font-heading);">
        {{ page.title }}
      </h1>
    </div>

    <!-- Page Content -->
    <div class="prose prose-invert max-w-none font-light text-gray-300 leading-relaxed space-y-6">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main Page Content",
  "settings": []
}
{% endschema %}
