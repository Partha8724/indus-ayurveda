<section class="py-24 bg-luxury-black text-white min-h-screen" id="shopify-section-main-list-collections" style="background-color: var(--color-bg);">
  <div class="max-w-7xl mx-auto px-6 md:px-12 animate-on-scroll">
    <div class="mb-16 border-b border-white/10 pb-8 text-center max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-serif mb-4" style="font-family: var(--font-heading);">
        Our Collections
      </h1>
      <p class="text-gray-400 font-light text-sm">
        Curate your longevity path. Explore our high-potency formulations arranged by category.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      {% for collection in collections %}
        {% unless collection.handle == 'frontpage' %}
          <a href="{{ collection.url }}" class="group relative flex flex-col border border-white/10 bg-white/5 hover:border-luxury-gold/50 transition-all p-8 text-center">
            <div class="aspect-square overflow-hidden bg-white/5 mb-6">
              {% if collection.image %}
                <img src="{{ collection.image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" class="w-full h-full object-cover transition-transform duration-750 group-hover:scale-103">
              {% elsif collection.products.first.featured_media != blank %}
                <img src="{{ collection.products.first.featured_media | image_url: width: 600 }}" alt="{{ collection.title | escape }}" class="w-full h-full object-cover transition-transform duration-750 group-hover:scale-103">
              {% else %}
                {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full text-white/10' }}
              {% endif %}
            </div>

            <h2 class="text-2xl font-serif text-white group-hover:text-luxury-gold transition-colors mb-2 font-sans" style="font-family: var(--font-heading);">
              {{ collection.title }}
            </h2>
            <p class="text-xs font-mono text-[#d4af37] uppercase tracking-widest" style="color: var(--color-accent);">
              {{ collection.all_products_count }} Formulations
            </p>
          </a>
        {% endunless %}
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "List Collections",
  "settings": []
}
{% endschema %}
