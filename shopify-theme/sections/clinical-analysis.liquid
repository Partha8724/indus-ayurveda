<section class="bg-white text-black border-t border-white/20" id="shopify-section-clinical-analysis">
  <div class="py-16 md:py-32 text-center max-w-4xl mx-auto px-6 animate-on-scroll transition-all duration-1000 transform translate-y-10 opacity-0">
    <p class="uppercase tracking-[0.3em] text-xs font-bold text-gray-500 mb-6" style="color: var(--color-accent);">
      {{ section.settings.tag | default: 'Deep Dive' }}
    </p>
    <h2 class="text-4xl md:text-6xl mb-8 font-serif" style="font-family: var(--font-heading);">
      {{ section.settings.heading | default: 'Clinical Analysis' }}
    </h2>
    <p class="text-gray-600 font-light text-xl leading-relaxed">
      {{ section.settings.description | default: 'A comprehensive breakdown of our most advanced formulation. Peer-reviewed ingredients, exponential efficacy.' }}
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Clinical Deep Dive Summary",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Deep Dive Subheading tagline",
      "default": "Deep Dive"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Deep Dive Title Heading",
      "default": "Clinical Analysis"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Deep Dive long form explanation text",
      "default": "A comprehensive breakdown of our most advanced formulation. Peer-reviewed ingredients, exponential efficacy."
    }
  ],
  "presets": [
    {
      "name": "Clinical Deep Dive Summary"
    }
  ]
}
{% endschema %}
