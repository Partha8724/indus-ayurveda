{% doc %}
  @prompt
    wrote indus ayurveda, wrote in indian anceint syle use ancaint font or color evry thing make anceint look organic athantic
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ancient-brand-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background: {{ block.settings.background_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
    position: relative;
    box-shadow: {{ block.settings.shadow_x }}px {{ block.settings.shadow_y }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_color }};
  }

  .ai-ancient-brand__ornament-top-{{ ai_gen_id }},
  .ai-ancient-brand__ornament-bottom-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.ornament_height }}px;
    background: linear-gradient(90deg, 
      transparent 0%, 
      {{ block.settings.ornament_color }} 20%, 
      {{ block.settings.ornament_color }} 50%, 
      {{ block.settings.ornament_color }} 80%, 
      transparent 100%
    );
    opacity: {{ block.settings.ornament_opacity }};
  }

  .ai-ancient-brand__ornament-top-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.ornament_spacing }}px;
  }

  .ai-ancient-brand__ornament-bottom-{{ ai_gen_id }} {
    margin-top: {{ block.settings.ornament_spacing }}px;
  }

  .ai-ancient-brand__content-{{ ai_gen_id }} {
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: {{ block.settings.font_family.weight }};
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
    line-height: {{ block.settings.line_height }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    margin: 0;
    text-transform: {{ block.settings.text_transform }};
    text-shadow: {{ block.settings.text_shadow_x }}px {{ block.settings.text_shadow_y }}px {{ block.settings.text_shadow_blur }}px {{ block.settings.text_shadow_color }};
  }

  .ai-ancient-brand__pattern-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: {{ block.settings.pattern_opacity }};
    pointer-events: none;
    background-image: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 10px,
      {{ block.settings.pattern_color }} 10px,
      {{ block.settings.pattern_color }} 11px
    );
    border-radius: {{ block.settings.border_radius }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-ancient-brand-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-ancient-brand__content-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.8);
    }
  }
{% endstyle %}

<div class="ai-ancient-brand-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_pattern %}
    <div class="ai-ancient-brand__pattern-{{ ai_gen_id }}"></div>
  {% endif %}
  
  {% if block.settings.show_ornaments %}
    <div class="ai-ancient-brand__ornament-top-{{ ai_gen_id }}"></div>
  {% endif %}
  
  {% if block.settings.brand_text != blank %}
    <div class="ai-ancient-brand__content-{{ ai_gen_id }}">
      {{ block.settings.brand_text }}
    </div>
  {% else %}
    <div class="ai-ancient-brand__content-{{ ai_gen_id }}" style="color: #999; font-style: italic;">
      Add your ancient brand text
    </div>
  {% endif %}
  
  {% if block.settings.show_ornaments %}
    <div class="ai-ancient-brand__ornament-bottom-{{ ai_gen_id }}"></div>
  {% endif %}
</div>

