<section class="py-24 bg-luxury-black text-white" id="shopify-section-main-collection" style="background-color: var(--color-bg);">
  <div class="max-w-7xl mx-auto px-6 md:px-12 animate-on-scroll">
    <div class="mb-12 border-b border-white/10 pb-8 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <h1 class="text-4xl md:text-5xl font-serif mb-4" style="font-family: var(--font-heading);">
          {{ collection.title }}
        </h1>
        {% if collection.description != blank %}
          <p class="text-gray-400 font-light text-sm max-w-xl">
            {{ collection.description }}
          </p>
        {% endif %}
      </div>
      
      <!-- Quick Info / Counter -->
      <div class="text-sm font-mono text-luxury-gold tracking-widest uppercase mb-1" style="color: var(--color-accent);">
        {{ collection.all_products_count }} Products Available
      </div>
    </div>

    <!-- Product Grid listing -->
    {%- paginate collection.products by 12 -%}
      {% if collection.products.size > 0 %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
          {% for product in collection.products %}
            <a href="{{ product.url }}" class="group block interactive-card border border-white/5 bg-white/5 hover:border-luxury-gold hover:bg-white/10 transition-all p-6 relative">
              <div class="aspect-square w-full overflow-hidden bg-white/5 mb-6">
                {% if product.featured_media != blank %}
                  <img 
                    src="{{ product.featured_media | image_url: width: 600 }}" 
                    alt="{{ product.title | escape }}" 
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  >
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'w-full h-full text-white/10' }}
                {% endif %}
              </div>

              <div class="text-xs uppercase tracking-widest text-[#d4af37] mb-2 font-bold" style="color: var(--color-accent);">
                {{ product.vendor }}
              </div>
              <h3 class="text-lg font-serif mb-2 text-white group-hover:text-luxury-gold transition-colors font-sans" style="font-family: var(--font-heading);">
                {{ product.title }}
              </h3>
              <div class="text-sm font-mono text-gray-400">
                {{ product.price | money }}
              </div>
            </a>
          {% endfor %}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="mt-16 flex justify-center gap-4">
            {%- if paginate.previous-%}
              <a href="{{ paginate.previous.url }}" class="px-4 py-2 border border-white/20 text-xs uppercase tracking-widest hover:border-white transition-colors">Previous</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="px-4 py-2 border border-white/10 text-xs hover:border-white transition-colors">{{ part.title }}</a>
              {%- else -%}
                <span class="px-4 py-2 border border-luxury-gold bg-[#d4af37]/10 text-[#d4af37] text-xs font-bold" style="border-color: var(--color-accent); color: var(--color-accent);">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="px-4 py-2 border border-white/20 text-xs uppercase tracking-widest hover:border-white transition-colors">Next</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      {% else %}
        <div class="py-24 text-center">
          <p class="text-gray-400 font-light mb-6">No products found in this collection.</p>
          <a href="/collections/all" class="inline-block border border-white/30 text-white px-8 py-4 uppercase tracking-widest text-sm font-medium hover:bg-white hover:text-black hover:border-white transition-all interactive-element">View All Formulations</a>
        </div>
      {% endif %}
    {%- endpaginate -%}

  </div>
</section>

{% schema %}
{
  "name": "Main Collection",
  "settings": []
}
{% endschema %}
