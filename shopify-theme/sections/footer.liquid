<footer class="bg-[#050505] text-white border-t border-white/5 pt-24 pb-12" id="shopify-section-footer">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-16 mb-20">
      
      <!-- Column 1: Newsletter & Apothecary Logo -->
      <div class="lg:col-span-5 space-y-8">
        <a href="{{ routes.root_url }}" class="flex items-center gap-3 select-none interactive-element">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-luxury-gold"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 2.5 1 8a7 7 0 0 1-9 10Z"></path><path d="M9 22v-3H6"></path></svg>
          <div class="flex flex-col items-start translate-y-[2px]">
            <span class="font-serif tracking-[0.15em] uppercase font-bold text-white text-xl leading-none">Indus</span>
            <span class="uppercase tracking-[0.4em] text-luxury-gold mt-1 leading-none font-medium text-[8px]">Ayurveda</span>
          </div>
        </a>
        <p class="text-gray-400 font-light text-sm max-w-sm leading-relaxed">
          {{ section.settings.description | default: 'Science-led therapeutics formulated with ancient Vedic wisdom. Uncovering raw bioavailability benchmarks.' }}
        </p>

        <!-- Newsletter Subscription Form -->
        <div class="pt-4">
          <p class="text-xs uppercase tracking-widest font-bold mb-4">Subscribe to the Protocol Dispatch</p>
          {% form 'customer', class: 'relative w-full max-w-md' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input 
              type="email" 
              name="contact[email]" 
              placeholder="Enter your email address" 
              class="w-full bg-transparent border-b border-white/10 pb-3 pr-10 text-sm text-white placeholder-gray-600 focus:outline-none focus:border-luxury-gold" 
              required
            >
            <button type="submit" class="absolute right-0 bottom-3 text-luxury-gold hover:text-white transition-colors interactive-element">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" x2="19" y1="12" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </button>
          {% endform %}
        </div>
      </div>

      <!-- Column 2: Quick Links Menu 1 -->
      <div class="lg:col-span-2 lg:col-start-7">
        <h4 class="text-xs uppercase tracking-[0.2em] font-bold text-luxury-gold mb-8">{{ section.settings.menu_1_title | default: 'Apothecary' }}</h4>
        <ul class="space-y-4 text-sm font-light text-gray-400">
          {% for link in linklists[section.settings.menu_1].links %}
            <li><a href="{{ link.url }}" class="hover:text-white transition-colors py-1 block interactive-element">{{ link.title }}</a></li>
          {% else %}
            <li><a href="#" class="hover:text-white transition-all py-1 block interactive-element">Cellular Renewal</a></li>
            <li><a href="#" class="hover:text-white transition-all py-1 block interactive-element">Vitality Elixirs</a></li>
            <li><a href="#" class="hover:text-white transition-all py-1 block interactive-element">Immune Resilience</a></li>
            <li><a href="#" class="hover:text-white transition-all py-1 block interactive-element">Detox Cleanse</a></li>
          {% endfor %}
        </ul>
      </div>

      <!-- Column 3: Quick Links Menu 2 -->
      <div class="lg:col-span-2">
        <h4 class="text-xs uppercase tracking-[0.2em] font-bold text-luxury-gold mb-8">{{ section.settings.menu_2_title | default: 'Client Service' }}</h4>
        <ul class="space-y-4 text-sm font-light text-gray-400">
          {% for link in linklists[section.settings.menu_2].links %}
            <li><a href="{{ link.url }}" class="hover:text-white transition-colors py-1 block interactive-element">{{ link.title }}</a></li>
          {% else %}
            <li><a href="#" class="hover:text-white transition-all py-1 block interactive-element">Consultations</a></li>
            <li><a href="#" class="hover:text-white transition-all py-1 block interactive-element">Shipping & Returns</a></li>
            <li><a href="#" class="hover:text-white transition-all py-1 block interactive-element">Scientific Advisory</a></li>
            <li><a href="#" class="hover:text-white transition-all py-1 block interactive-element">Corporate Concierge</a></li>
          {% endfor %}
        </ul>
      </div>

      <!-- Column 4: Quick Links Menu 3 -->
      <div class="lg:col-span-2">
        <h4 class="text-xs uppercase tracking-[0.2em] font-bold text-luxury-gold mb-8">{{ section.settings.menu_3_title | default: 'Corporate' }}</h4>
        <ul class="space-y-4 text-sm font-light text-gray-400">
          {% for link in linklists[section.settings.menu_3].links %}
            <li><a href="{{ link.url }}" class="hover:text-white transition-colors py-1 block interactive-element">{{ link.title }}</a></li>
          {% else %}
            <li><a href="#" class="hover:text-white transition-all py-1 block interactive-element">Our Story</a></li>
            <li><a href="#" class="hover:text-white transition-all py-1 block interactive-element">Clinical Trials</a></li>
            <li><a href="#" class="hover:text-white transition-all py-1 block interactive-element">Sourcing Integrity</a></li>
            <li><a href="#" class="hover:text-white transition-all py-1 block interactive-element">Privacy Policy</a></li>
          {% endfor %}
        </ul>
      </div>

    </div>

    <!-- Bottom copyright metadata row -->
    <div class="border-t border-white/5 pt-12 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="text-xs text-gray-500 font-light flex items-center gap-2">
        <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name | default: 'Indus Ayurveda' }}. All rights reserved.</span>
        <span class="text-gray-700">|</span>
        <span>Online Store 2.0 Compliant Formulation</span>
      </div>
      
      <!-- Payments dynamic badge symbols representation standard array -->
      <div class="flex items-center gap-4 text-gray-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="opacity-40 hover:opacity-100 transition-opacity"><rect width="20" height="14" x="2" y="5" rx="2"></rect><line x1="2" x2="22" y1="10" y2="10"></line></svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="opacity-40 hover:opacity-100 transition-opacity"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path><path d="M2 12h20"></path></svg>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Luxury Footer Dynamic",
  "settings": [
    {
      "type": "textarea",
      "id": "description",
      "label": "About Indus Short Paragraph",
      "default": "Science-led therapeutics formulated with ancient Vedic wisdom. Uncovering raw bioavailability benchmarks."
    },
    {
      "type": "text",
      "id": "menu_1_title",
      "label": "Menu 1 Column Title Theme",
      "default": "Apothecary"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Menu 1 Linklist Selection"
    },
    {
      "type": "text",
      "id": "menu_2_title",
      "label": "Menu 2 Column Title Theme",
      "default": "Client Service"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Menu 2 Linklist Selection"
    },
    {
      "type": "text",
      "id": "menu_3_title",
      "label": "Menu 3 Column Title Theme",
      "default": "Corporate"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "Menu 3 Linklist Selection"
    }
  ]
}
{% endschema %}
