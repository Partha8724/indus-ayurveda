<section class="relative py-32 overflow-hidden bg-luxury-black" id="shopify-section-brand-story" style="background-color: var(--color-bg);">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <!-- Left column: Asymmetrical Offset Double Images structure -->
      <div class="relative">
        <div class="aspect-[4/5] w-4/5 overflow-hidden ml-auto animate-on-scroll transition-all duration-1000 transform translate-y-10 opacity-0">
          {% if section.settings.image_1 != blank %}
            <img src="{{ section.settings.image_1 | image_url: width: 1000 }}" alt="Raw Ayurveda Origins" class="w-full h-full object-cover">
          {% else %}
            <img src="https://images.unsplash.com/photo-1542841791-172776c52aef?auto=format&fit=crop&q=80&w=1000" alt="Ingredients" class="w-full h-full object-cover">
          {% endif %}
        </div>
        
        <div class="absolute bottom-[-10%] left-0 w-3/5 aspect-square border-[8px] border-luxury-black overflow-hidden animate-on-scroll transition-all duration-1000 transform translate-y-10 opacity-0" style="border-color: var(--color-bg); transition-delay: 200ms;">
          {% if section.settings.image_2 != blank %}
            <img src="{{ section.settings.image_2 | image_url: width: 800 }}" alt="Modern laboratory distillation" class="w-full h-full object-cover">
          {% else %}
            <img src="https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?auto=format&fit=crop&q=80&w=1000" alt="Extraction" class="w-full h-full object-cover">
          {% endif %}
        </div>
      </div>

      <!-- Right column: Modern narrative content layout -->
      <div class="lg:pl-12 lg:mt-0 mt-16 animate-on-scroll transition-all duration-1000 transform translate-y-10 opacity-0" style="transition-delay: 400ms;">
        <p class="text-luxury-gold uppercase tracking-[0.2em] text-sm mb-6 font-medium" style="color: var(--color-accent);">
          {{ section.settings.tag | default: 'Purity & Potency' }}
        </p>
        
        <h2 class="text-4xl md:text-5xl text-white leading-tight mb-8 font-serif" style="font-family: var(--font-heading);">
          {{ section.settings.heading | default: 'The Science of True Vitality' }}
        </h2>

        <div class="space-y-6 text-gray-400 font-light text-lg">
          <p>
            {{ section.settings.paragraph_1 | default: 'Founded on the principles of holistic wellness and uncompromising purity, our formulations bridge the gap between ancient natural wisdom and modern medical science.' }}
          </p>
          <p>
            {{ section.settings.paragraph_2 | default: 'Every extract, compound, and mineral is obsessively sourced to deliver maximum bioavailability and transformative results. We do not just create supplements; we engineer the foundation of your health.' }}
          </p>
        </div>

        <div class="mt-12">
          {% if section.settings.button_label != blank %}
            <a href="{{ section.settings.button_link }}" class="inline-block border border-white/30 text-white px-8 py-4 uppercase tracking-widest text-sm font-medium hover:bg-white hover:text-black hover:border-white transition-all interactive-element">
              {{ section.settings.button_label }}
            </a>
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Luxury Offline Brand Story",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Asymmetrical Top/Right Image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Asymmetrical Bottom/Left Image"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Category Tagline label",
      "default": "Purity & Potency"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Major Title Heading",
      "default": "The Science of True Vitality"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Story First Paragraph narration",
      "default": "Founded on the principles of holistic wellness and uncompromising purity, our formulations bridge the gap between ancient natural wisdom and modern medical science."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Story Second Paragraph narration",
      "default": "Every extract, compound, and mineral is obsessively sourced to deliver maximum bioavailability and transformative results. We do not just create supplements; we engineer the foundation of your health."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Story Button CTA Label",
      "default": "Discover Our Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link destination"
    }
  ],
  "presets": [
    {
      "name": "Luxury Offline Brand Story"
    }
  ]
}
{% endschema %}
