<article class="py-24 bg-luxury-black text-white min-h-screen" id="shopify-section-main-article" style="background-color: var(--color-bg);">
  <div class="max-w-3xl mx-auto px-6 md:px-12 animate-on-scroll">
    
    <!-- Meta and Title header -->
    <div class="mb-12 text-center">
      <div class="flex items-center justify-center gap-4 text-xs font-mono text-[#d4af37] mb-4 uppercase tracking-widest" style="color: var(--color-accent);">
        <span>{{ article.published_at | date: "%B %d, %Y" }}</span>
        <span>•</span>
        <span>By {{ article.author }}</span>
      </div>

      <h1 class="text-4xl md:text-5xl font-serif mb-6 leading-tight" style="font-family: var(--font-heading);">
        {{ article.title }}
      </h1>
      
      {% if article.image %}
        <div class="aspect-[16/9] overflow-hidden bg-white/5 border border-white/10 mt-12 mb-16">
          <img src="{{ article.image | image_url: width: 1200 }}" alt="{{ article.title | escape }}" class="w-full h-full object-cover">
        </div>
      {% endif %}
    </div>

    <!-- Article Content -->
    <div class="prose prose-invert prose-gold max-w-none font-light text-gray-300 leading-relaxed space-y-6 text-lg">
      {{ article.content }}
    </div>

    <!-- Navigation link -->
    <div class="mt-16 pt-8 border-t border-white/10 flex justify-between">
      <a href="{{ blog.url }}" class="text-xs font-bold uppercase tracking-widest text-[#d4af37] hover:text-white transition-colors flex items-center gap-1 font-sans" style="color: var(--color-accent);">
        ← Back to {{ blog.title }}
      </a>
    </div>

  </div>
</article>

{% schema %}
{
  "name": "Main Article View",
  "settings": []
}
{% endschema %}
