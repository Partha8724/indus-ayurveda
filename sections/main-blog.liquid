<section class="py-24 bg-luxury-black text-white" id="shopify-section-main-blog" style="background-color: var(--color-bg);">
  <div class="max-w-7xl mx-auto px-6 md:px-12 animate-on-scroll">
    <div class="mb-16 border-b border-white/10 pb-8 text-center max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-serif mb-4" style="font-family: var(--font-heading);">
        {{ blog.title }}
      </h1>
      <p class="text-gray-400 font-light text-sm">
        Discover the scientific publications, medical insights, and ancient journals backing our botanical matrices.
      </p>
    </div>

    {%- paginate blog.articles by 6 -%}
      {% if blog.articles.size > 0 %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
          {% for article in blog.articles %}
            <article class="group relative flex flex-col h-full border border-white/10 bg-white/5 hover:border-luxury-gold/50 transition-all p-8">
              {% if article.image %}
                <div class="aspect-[16/10] overflow-hidden bg-white/5 mb-6">
                  <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title | escape }}" class="w-full h-full object-cover transition-transform duration-750 group-hover:scale-103">
                </div>
              {% endif %}

              <div class="flex items-center gap-4 text-xs font-mono text-[#d4af37] mb-4 uppercase tracking-widest" style="color: var(--color-accent);">
                <span>{{ article.published_at | date: "%b %d, %Y" }}</span>
                <span>•</span>
                <span>By {{ article.author }}</span>
              </div>

              <h2 class="text-2xl font-serif mb-4 text-white font-sans group-hover:text-luxury-gold transition-colors" style="font-family: var(--font-heading);">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h2>

              <p class="text-gray-400 font-light text-sm leading-relaxed mb-6 line-clamp-3">
                {% if article.excerpt.size > 0 %}
                  {{ article.excerpt | strip_html }}
                {% else %}
                  {{ article.content | strip_html | truncate: 180 }}
                {% endif %}
              </p>

              <a href="{{ article.url }}" class="mt-auto text-xs font-bold uppercase tracking-widest text-[#d4af37] hover:text-white transition-colors flex items-center gap-1 font-sans" style="color: var(--color-accent);">
                Read Article →
              </a>
            </article>
          {% endfor %}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="mt-16 flex justify-center gap-4">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="px-4 py-2 border border-white/20 text-xs uppercase tracking-widest hover:border-white transition-colors">Previous</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="px-4 py-2 border border-white/10 text-xs hover:border-white transition-colors">{{ part.title }}</a>
              {%- else -%}
                <span class="px-4 py-2 border border-luxury-gold bg-[#d4af37]/10 text-[#d4af37] text-xs font-bold" style="border-color: var(--color-accent); color: var(--color-accent);">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="px-4 py-2 border border-white/20 text-xs uppercase tracking-widest hover:border-white transition-colors">Next</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      {% else %}
        <div class="py-24 text-center">
          <p class="text-gray-400 font-light">No publications found at this moment.</p>
        </div>
      {% endif %}
    {%- endpaginate -%}

  </div>
</section>

{% schema %}
{
  "name": "Main Blog Curation",
  "settings": []
}
{% endschema %}
